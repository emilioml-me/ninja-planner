# ── Staging (/srv/secrets/ninja-planner.stg.env) ─────────────────────────────
NODE_ENV=production
PORT=3206

# PostgreSQL — staging DB on 10.10.1.60:25061
DATABASE_URL=postgresql://plan_ninjausr:PASSWORD@10.10.1.60:25061/plan_ninja_stg?sslmode=disable

# Clerk staging app keys (Clerk dashboard → API keys)
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SECRET=whsec_...

# Must match the staging domain exactly (used for CORS)
ALLOWED_ORIGIN=https://ninja-planner.njn-stg.com

# ── Build-time arg (also needed in docker-compose args section) ───────────────
# Baked into the React bundle by Vite — NOT a runtime secret
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# ── Integrations (all optional — omit to disable a service) ──────────────────
# client-ninja (CRM)
CRM_NINJA_URL=https://crm.njn-stg.com
CRM_NINJA_API_KEY=

# payment-ninja
PAYMENT_NINJA_URL=https://payments.njn-stg.com
PAYMENT_NINJA_API_KEY=

# desk-ninja (helpdesk)
DESK_NINJA_URL=https://desk.njn-stg.com
DESK_NINJA_API_KEY=

# ninja-schedule
NINJA_SCHEDULE_URL=https://schedule.njn-stg.com
NINJA_SCHEDULE_API_KEY=

